<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AroniumFactures.ViewModels"
        x:Class="AroniumFactures.CompanionAppPathDialog"
        x:DataType="vm:CompanionAppPathDialogViewModel"
        Title="Aronium Lite - Chemin requis"
        Width="500" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,*">
        <TextBlock Text="Aucun chemin valide vers Aronium Lite. Veuillez sélectionner l'exécutable de l'application principale."
                   TextWrapping="Wrap"
                   FontSize="14"
                   Margin="0,0,0,15"/>
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="Exécutable (ex: Aronium.Pos.exe):" FontWeight="SemiBold"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Text="{Binding SelectedPath, Mode=TwoWay}"
                         Watermark="C:\Program Files\Aronium\Aronium.Pos.exe"
                         Padding="10,8"/>
                <Button Grid.Column="1"
                        Content="Parcourir..."
                        Command="{Binding BrowseCommand}"
                        Margin="10,0,0,0"
                        Padding="20,8"
                        Background="#6366F1"
                        Foreground="White"
                        CornerRadius="6"
                        BorderThickness="0"/>
            </Grid>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Annuler" Click="Cancel_Click" Padding="20,10" Background="#6B7280" Foreground="White" CornerRadius="6" BorderThickness="0"/>
            <Button Content="OK" Click="Submit_Click" Padding="20,10" Background="#2563EB" Foreground="White" CornerRadius="6" BorderThickness="0" IsEnabled="{Binding IsValid}"/>
        </StackPanel>
    </Grid>
</Window>
