<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HelloAvalonia.ViewModels"
        xmlns:local="clr-namespace:HelloAvalonia"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
        x:Class="HelloAvalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{x:Static local:Strings.AppTitle}"
        Width="1000" Height="800"
        Background="#F0F2F5">
    
    <Grid>
        <ScrollViewer IsEnabled="{Binding IsInteractive}">
            <Grid Margin="30" RowDefinitions="Auto,*">
            <!-- Top Bar with Create Button and Settings -->
            <Grid ColumnDefinitions="*,Auto">
                <Button Content="{x:Static local:Strings.CreateInvoiceButton}"
                        HorizontalAlignment="Left"
                        Padding="20,12"
                        Margin="0,0,0,20"
                        Command="{Binding ShowFormCommand}"
                        Background="#2563EB"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        CornerRadius="8"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#1D4ED8"/>
                        </Style>
                    </Button.Styles>
                </Button>
                
                <!-- Settings Button (Top Right) -->
                <Button Grid.Column="1"
                        Content="⚙️ Paramètres"
                        Command="{Binding OpenSettingsCommand}"
                        HorizontalAlignment="Right"
                        Padding="15,10"
                        Margin="0,0,0,20"
                        Background="#6B7280"
                        Foreground="White"
                        FontSize="13"
                        CornerRadius="8"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#4B5563"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>

            <!-- Invoice Form -->
            <Border Grid.Row="1"
                    Padding="40"
                    CornerRadius="12"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Background="White"
                    IsVisible="{Binding ShowForm}"
                    BoxShadow="0 4 6 -1 #10000000, 0 2 4 -1 #06000000">
                <StackPanel Spacing="0">
                    <!-- Header Section -->
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,20">
                        <!-- Logo Section (Left) -->
                        <StackPanel Spacing="10" Margin="0,0,20,0">
                            <Border Width="100" 
                                    Height="80"
                                    CornerRadius="8">
                                <Image Source="{Binding LogoImage}" 
                                       Stretch="Uniform"
                                       IsVisible="{Binding HasLogo}"/>
                            </Border>
                            <StackPanel Spacing="6">
                                <Button Content="{x:Static local:Strings.ChooseLogo}"
                                        Command="{Binding ChooseLogoCommand}"
                                        HorizontalAlignment="Center"
                                        Padding="10,6"
                                        FontSize="11"
                                        Background="#6366F1"
                                        Foreground="White"
                                        CornerRadius="6"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="#4F46E5"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                                <Button Content="Supprimer"
                                        Command="{Binding RemoveLogoCommand}"
                                        HorizontalAlignment="Center"
                                        Padding="10,6"
                                        FontSize="11"
                                        Background="#EF4444"
                                        Foreground="White"
                                        CornerRadius="6"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        IsVisible="{Binding HasLogo}">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="#DC2626"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Company Name (Right of Logo) -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBox Text="{Binding CompanyName, Mode=TwoWay}"
                                     FontSize="24"
                                     FontWeight="Bold"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Watermark="{x:Static local:Strings.CompanyName}"/>
                            <TextBlock Text="{x:Static local:Strings.InvoiceTitle}"
                                       FontSize="16"
                                       Margin="0,5,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3,0,0">
                                <TextBlock Text="{Binding ProductCountDisplay}"
                                           FontSize="13"
                                           Foreground="#6B7280"/>
                                <Button Content="Rafraichir"
                                        Command="{Binding LoadProductCountCommand}"
                                        Padding="8,4"
                                        FontSize="11"
                                        Background="#2563EB"
                                        Foreground="White"
                                        BorderThickness="0"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="#1D4ED8"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Invoice Info and Client Section -->
                    <Grid ColumnDefinitions="300,*" Margin="0,0,0,25">
                        <!-- Left: Invoice Info Box -->
                        <Border BorderBrush="#D1D5DB" 
                                BorderThickness="2" 
                                Padding="15"
                                CornerRadius="8"
                                Background="#F9FAFB">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="{x:Static local:Strings.InvoiceNumber}" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,8,0"
                                               Foreground="#374151"/>
                                    <TextBox Grid.Column="1" Text="{Binding InvoiceNumber, Mode=TwoWay}" 
                                             BorderThickness="0" Background="Transparent" Padding="0"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="{x:Static local:Strings.InvoiceDate}" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,8,0"
                                               Foreground="#374151"/>
                                    <TextBox Grid.Column="1" Text="{Binding InvoiceDateString, Mode=TwoWay}" 
                                             BorderThickness="0" Background="Transparent" Padding="0"
                                             Watermark="JJ/MM/AAAA"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="{x:Static local:Strings.PaymentType}" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,8,0"
                                               Foreground="#374151"/>
                                    <TextBox Grid.Column="1" Text="{Binding PaymentType, Mode=TwoWay}" 
                                             BorderThickness="0" Background="Transparent" Padding="0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Right: Client Info Box -->
                        <Border Grid.Column="1" 
                                BorderBrush="#D1D5DB" 
                                BorderThickness="2" 
                                Padding="18" 
                                Margin="15,0,0,0"
                                CornerRadius="8"
                                Background="#F9FAFB">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="{x:Static local:Strings.ClientLabel}" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,10,0"
                                               Foreground="#374151"/>
                                    <TextBox Grid.Column="1" Text="{Binding CustomerName, Mode=TwoWay}" 
                                             BorderThickness="0" Background="Transparent" Padding="0"
                                             Watermark="Nom du client"
                                             FontSize="13"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" Margin="0,15,0,0">
                                    <TextBlock Text="{x:Static local:Strings.ICELabel}" 
                                               FontWeight="SemiBold" 
                                               Margin="0,0,10,0"
                                               Foreground="#374151"/>
                                    <TextBox Grid.Column="1" Text="{Binding IceNumber, Mode=TwoWay}" 
                                             BorderThickness="0" Background="Transparent" Padding="0"
                                             Watermark="000000000000000"
                                             FontSize="13"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Items Table -->
                    <Border BorderBrush="#E5E7EB" 
                            BorderThickness="2" 
                            Margin="0,0,0,25"
                            CornerRadius="8"
                            BoxShadow="0 1 3 0 #0A000000">
                        <StackPanel>
                            <!-- Table Header -->
                            <Grid ColumnDefinitions="80,*,80,100,80,100,60" 
                                  Background="#F3F4F6" 
                                  Height="40">
                                <TextBlock Grid.Column="0" Text="{x:Static local:Strings.RefColumn}" 
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                <TextBlock Grid.Column="1" Text="{x:Static local:Strings.DesignationColumn}" 
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{x:Static local:Strings.QtyColumn}" 
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                <TextBlock Grid.Column="3" Text="{x:Static local:Strings.PriceColumn}" 
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                <TextBlock Grid.Column="4" Text="{x:Static local:Strings.TVAColumn}" 
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                <TextBlock Grid.Column="5" Text="{x:Static local:Strings.TotalColumn}" 
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                <TextBlock Grid.Column="6" Text="" 
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                            </Grid>

                            <!-- Items List -->
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="80,*,80,100,80,100,60" MinHeight="40">
                                                <TextBox Grid.Column="0" Text="{Binding Reference, Mode=TwoWay}" 
                                                         BorderThickness="0" VerticalAlignment="Center" Margin="5,0"/>
                                                <TextBox Grid.Column="1" Text="{Binding Designation, Mode=TwoWay}" 
                                                         BorderThickness="0" VerticalAlignment="Center" Margin="5,0"
                                                         TextWrapping="Wrap" AcceptsReturn="True"/>
                                                <TextBox Grid.Column="2" Text="{Binding Quantity, Mode=TwoWay}" 
                                                         BorderThickness="0" VerticalAlignment="Center" Margin="5,0"/>
                                                <TextBox Grid.Column="3" Text="{Binding UnitPrice, Mode=TwoWay}" 
                                                         BorderThickness="0" VerticalAlignment="Center" Margin="5,0"/>
                                                <TextBox Grid.Column="4" Text="{Binding TvaRate, Mode=TwoWay}" 
                                                         BorderThickness="0" VerticalAlignment="Center" Margin="5,0"/>
                                                <TextBlock Grid.Column="5" Text="{Binding TotalTTC, StringFormat={}{0:F2}}" 
                                                           VerticalAlignment="Center" Margin="5,0"/>
                                                <Button Grid.Column="6" 
                                                        Content="✕"
                                                        FontSize="16"
                                                        Foreground="Red"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="5"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RemoveItemCommand}"
                                                        CommandParameter="{Binding}"
                                                        Cursor="Hand"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add/Remove Buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="10,15">
                                <Button Content="{x:Static local:Strings.AddItemButton}"
                                        Command="{Binding AddItemCommand}"
                                        Padding="14,8"
                                        Background="#10B981"
                                        Foreground="White"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        CornerRadius="6"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="#059669"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Totals Section -->
                    <Grid ColumnDefinitions="*,250" Margin="0,20,0,0">
                        <StackPanel Grid.Column="1">
                            <Border BorderBrush="#E5E7EB" 
                                    BorderThickness="2" 
                                    Padding="20"
                                    CornerRadius="8"
                                    Background="#F9FAFB"
                                    BoxShadow="0 1 3 0 #0A000000">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{x:Static local:Strings.TotalHT}" 
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="#374151"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalHT, StringFormat={}{0:F2} DH}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="13"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#374151"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{x:Static local:Strings.Taxe}" 
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="#374151"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalTaxe, StringFormat={}{0:F2} DH}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="13"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#374151"/>
                                    </Grid>
                                    <Rectangle Height="2" Fill="#D1D5DB" Margin="0,8"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{x:Static local:Strings.TotalTTC}" 
                                                   FontWeight="Bold" 
                                                   FontSize="17"
                                                   Foreground="#1F2937"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalTTC, StringFormat={}{0:F2} DH}" 
                                                   FontWeight="Bold" 
                                                   FontSize="17" 
                                                   HorizontalAlignment="Right"
                                                   Foreground="#2563EB"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Amount in Words Section -->
                    <StackPanel Margin="0,25,0,0">
                        <TextBlock Text="{x:Static local:Strings.AmountInWords}" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Foreground="#374151"/>
                        <Border BorderBrush="#E5E7EB" 
                                BorderThickness="2" 
                                Padding="16"
                                Background="#FEF3C7"
                                CornerRadius="8"
                                BoxShadow="0 1 3 0 #0A000000">
                            <TextBlock Text="{Binding TotalInWords}" 
                                       FontSize="15"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Foreground="#92400E"/>
                        </Border>
                    </StackPanel>

                    <!-- Footer -->
                    <TextBox Text="{Binding CompanyAddress, Mode=TwoWay}"
                             Margin="0,20,0,0"
                             FontSize="9"
                             TextAlignment="Center"
                             BorderThickness="0"
                             Background="Transparent"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Watermark="{x:Static local:Strings.CompanyAddress}"/>
                </StackPanel>
            </Border>
        </Grid>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Background="#AA000000"
                IsVisible="{Binding IsInitializing}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <ProgressBar Width="220"
                             IsIndeterminate="True"/>
                <TextBlock Text="{Binding InitializationMessage}"
                           Foreground="White"
                           FontSize="14"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Initialization failure overlay -->
        <Border Background="#CC1F2937"
                IsVisible="{Binding InitializationFailed}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="Impossible d'initialiser la base de donnees."
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="16"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding InitializationMessage}"
                           Foreground="White"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="320"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
