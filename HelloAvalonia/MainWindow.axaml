<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AroniumFactures.ViewModels"
        xmlns:local="clr-namespace:AroniumFactures"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
        x:Class="AroniumFactures.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{x:Static local:Strings.AppTitle}"
        Width="1000" Height="800"
        Background="#F0F2F5">
    
    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Update Banner -->
        <Border Grid.Row="0"
                Background="#10B981"
                Padding="15,12"
                IsVisible="{Binding IsUpdateAvailable}"
                Cursor="Hand">
            <Border.Styles>
                <Style Selector="Border:pointerover">
                    <Setter Property="Background" Value="#059669"/>
                </Style>
            </Border.Styles>
            <Button Command="{Binding DownloadUpdateCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="🔄 Une nouvelle mise à jour est disponible. Cliquez pour télécharger et installer."
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="⬇️"
                               Foreground="White"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </Grid>
            </Button>
        </Border>
        
        <!-- Top Bar with Settings Button (Always Enabled) -->
        <Border Grid.Row="1"
                Background="White"
                Padding="15,10"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                BoxShadow="0 1 3 0 #10000000">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{x:Static local:Strings.AppTitle}"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="⚙️ Paramètres"
                        Command="{Binding OpenSettingsCommand}"
                        Background="#6B7280"
                        Foreground="White"
                        Padding="15,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        CornerRadius="6"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#4B5563"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>
        </Border>
        
        <ScrollViewer Grid.Row="2" IsEnabled="{Binding IsInteractive}">
            <Grid Margin="30" RowDefinitions="Auto,Auto,Auto,*">
            <!-- Document Search Section -->
            <Border Grid.Row="0" 
                    Background="White"
                    Padding="15"
                    CornerRadius="8"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Margin="0,0,0,15"
                    BoxShadow="0 1 3 0 #10000000">
                <Grid ColumnDefinitions="Auto,250,Auto,*,Auto,Auto">
                        <TextBlock Text="N° Document:" 
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Margin="0,0,15,0"/>
                        
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchDocumentNumber, Mode=TwoWay}"
                                 Watermark="25-200-000002"
                                 VerticalContentAlignment="Center"
                                 Padding="10,8"/>
                        
                        <Button Grid.Column="2"
                                Content="📄 Charger"
                                Command="{Binding LoadDocumentCommand}"
                                IsEnabled="{Binding !IsLoadingDocument}"
                                Margin="10,0,0,0"
                                Background="#10B981"
                                Foreground="White"
                                Padding="20,8"
                                FontWeight="SemiBold"
                                CornerRadius="6"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#059669"/>
                                </Style>
                                <Style Selector="Button:disabled">
                                    <Setter Property="Background" Value="#D1D5DB"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                        
                        <!-- Preview Button - Commented Out -->
                        <!--
                        <Button Grid.Column="3"
                                Content="👁️ Aperçu"
                                Command="{Binding PreviewInvoiceCommand}"
                                Margin="10,0,0,0"
                                Background="#6366F1"
                                Foreground="White"
                                Padding="15,8"
                                FontSize="13"
                                FontWeight="SemiBold"
                                CornerRadius="6"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#4F46E5"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                        -->
                        
                        <TextBlock Grid.Column="3"
                                   Text="{Binding LoadDocumentStatus}"
                                   VerticalAlignment="Center"
                                   Margin="15,0,0,0"
                                   FontSize="13"/>
                        
                        <!-- PDF Export Button -->
                        <Button Grid.Column="4"
                                Content="📄 Exporter PDF"
                                Command="{Binding ExportToPdfCommand}"
                                Margin="10,0,0,0"
                                Background="#DC2626"
                                Foreground="White"
                                Padding="15,8"
                                FontSize="13"
                                FontWeight="SemiBold"
                                CornerRadius="6"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#B91C1C"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                        
                        <!-- Print Button -->
                        <Button Grid.Column="5"
                                Content="🖨️ Imprimer"
                                Command="{Binding PrintCommand}"
                                Margin="10,0,0,0"
                                Background="#2563EB"
                                Foreground="White"
                                Padding="15,8"
                                FontSize="13"
                                FontWeight="SemiBold"
                                CornerRadius="6"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                </Grid>
            </Border>

            <!-- Document Type Selection Buttons -->
            <Border Grid.Row="1"
                    Background="White"
                    Padding="15"
                    CornerRadius="8"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Margin="0,0,0,15"
                    BoxShadow="0 1 3 0 #10000000">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="5">
                    <Button Content="📋 Devis"
                            Command="{Binding SelectDevisCommand}"
                            Background="#6366F1"
                            Foreground="White"
                            Padding="20,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            CornerRadius="6"
                            BorderThickness="0"
                            HorizontalContentAlignment="Center"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#4F46E5"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                    <Button Content="🚚 Bon de livraison"
                            Command="{Binding SelectBonLivraisonCommand}"
                            Background="#10B981"
                            Foreground="White"
                            Padding="20,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            CornerRadius="6"
                            BorderThickness="0"
                            HorizontalContentAlignment="Center"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#059669"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                    <Button Content="📝 Bon de commande"
                            Command="{Binding SelectBonCommandeCommand}"
                            Background="#F59E0B"
                            Foreground="White"
                            Padding="20,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            CornerRadius="6"
                            BorderThickness="0"
                            HorizontalContentAlignment="Center"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#D97706"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                    <Button Content="🧾 Facture"
                            Command="{Binding SelectFactureCommand}"
                            Background="#DC2626"
                            Foreground="White"
                            Padding="20,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            CornerRadius="6"
                            BorderThickness="0"
                            HorizontalContentAlignment="Center"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Document Type Chip -->
            <Grid Grid.Row="2">
                <Border IsVisible="{Binding HasDocumentType}"
                        Background="#DC2626"
                        BorderThickness="0"
                        CornerRadius="8"
                        Padding="16,10"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding DocumentTypeDisplay}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="White"/>
                </Border>
            </Grid>

            <!-- Content View Area -->
            <ContentControl Grid.Row="3"
                           Content="{Binding CurrentView}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>
          
        </Grid>
        </ScrollViewer>
    </Grid>
</Window>
