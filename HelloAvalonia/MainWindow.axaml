<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AroniumFactures.ViewModels"
        xmlns:local="clr-namespace:AroniumFactures"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
        x:Class="AroniumFactures.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{x:Static local:Strings.AppTitle}"
        Width="1000" Height="800"
        MinWidth="950" MinHeight="600"
        Background="#F0F2F5">
    
    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Update Banner -->
        <Border Grid.Row="0"
                Background="#10B981"
                Padding="15,12"
                IsVisible="{Binding IsUpdateAvailable}"
                Cursor="Hand">
            <Border.Styles>
                <Style Selector="Border:pointerover">
                    <Setter Property="Background" Value="#059669"/>
                </Style>
            </Border.Styles>
            <Button Command="{Binding DownloadUpdateCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="🔄 Une nouvelle mise à jour est disponible. Cliquez pour télécharger et installer."
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="⬇️"
                               Foreground="White"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </Grid>
            </Button>
        </Border>
        
        <!-- Top Bar with Settings Button (Always Enabled) -->
        <Border Grid.Row="1"
                Background="White"
                Padding="15,10"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                BoxShadow="0 1 3 0 #10000000">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{x:Static local:Strings.AppTitle}"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="⚙️ Paramètres"
                        Command="{Binding OpenSettingsCommand}"
                        Background="#6B7280"
                        Foreground="White"
                        Padding="15,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        CornerRadius="6"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#4B5563"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>
        </Border>
        
        <ScrollViewer Grid.Row="2" IsEnabled="{Binding IsInteractive}">
            <Grid Margin="30" RowDefinitions="Auto,*,Auto">
            <!-- Document Type Selection Buttons with Logo -->
            <Border Grid.Row="0"
                    Background="White"
                    Padding="15"
                    CornerRadius="8"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Margin="0,0,0,15"
                    BoxShadow="0 1 3 0 #10000000">
                <Grid ColumnDefinitions="Auto,*">
                    <!-- Logo Section -->
                    <Border Grid.Column="0"
                            Background="#F9FAFB"
                            BorderThickness="0"
                            CornerRadius="6"
                            Padding="15"
                            Margin="0,0,20,0"
                            Width="180"
                            Height="120">
                        <StackPanel HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Spacing="8">
                            <!-- Logo Display -->
                            <Border Background="White"
                                   BorderThickness="0"
                                   CornerRadius="4"
                                   Width="120"
                                   Height="80"
                                   HorizontalAlignment="Center"
                                   ClipToBounds="True">
                                <Grid>
                                    <Image Source="{Binding LogoImage}"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding HasLogo}"/>
                                    <TextBlock Text="Aucun logo"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="#9CA3AF"
                                              FontSize="11"
                                              IsVisible="{Binding !HasLogo}"/>
                                </Grid>
                            </Border>
                            
                            <!-- Logo Buttons -->
                            <StackPanel Orientation="Horizontal"
                                      HorizontalAlignment="Center"
                                      Spacing="5">
                                <Button Command="{Binding ChooseLogoCommand}"
                                       Content="📁 Choisir"
                                       Padding="10,6"
                                       Background="#2563EB"
                                       Foreground="White"
                                       BorderThickness="0"
                                       CornerRadius="4"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Cursor="Hand">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="#1D4ED8"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                                <Button Command="{Binding RemoveLogoCommand}"
                                       Content="🗑️"
                                       Padding="8,6"
                                       Background="#DC2626"
                                       Foreground="White"
                                       BorderThickness="0"
                                       CornerRadius="4"
                                       FontSize="11"
                                       Cursor="Hand"
                                       IsVisible="{Binding HasLogo}">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="#B91C1C"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Document Type Buttons -->
                    <StackPanel Grid.Column="1"
                               Orientation="Horizontal"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Spacing="5">
                        <Button Content="📋 Devis"
                               Command="{Binding SelectDevisCommand}"
                               Background="#6366F1"
                               Foreground="White"
                               Padding="20,12"
                               FontSize="14"
                               FontWeight="SemiBold"
                               CornerRadius="6"
                               BorderThickness="0"
                               HorizontalContentAlignment="Center"
                               Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#4F46E5"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                        
                        <Button Content="📝 Bon de commande"
                               Command="{Binding SelectBonCommandeCommand}"
                               Background="#F59E0B"
                               Foreground="White"
                               Padding="20,12"
                               FontSize="14"
                               FontWeight="SemiBold"
                               CornerRadius="6"
                               BorderThickness="0"
                               HorizontalContentAlignment="Center"
                               Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#D97706"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                        
                        <Button Content="🚚 Bon de livraison"
                               Command="{Binding SelectBonLivraisonCommand}"
                               Background="#10B981"
                               Foreground="White"
                               Padding="20,12"
                               FontSize="14"
                               FontWeight="SemiBold"
                               CornerRadius="6"
                               BorderThickness="0"
                               HorizontalContentAlignment="Center"
                               Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#059669"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                        
                        <Button Content="🧾 Facture"
                               Command="{Binding SelectFactureCommand}"
                               Background="#DC2626"
                               Foreground="White"
                               Padding="20,12"
                               FontSize="14"
                               FontWeight="SemiBold"
                               CornerRadius="6"
                               BorderThickness="0"
                               HorizontalContentAlignment="Center"
                               Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="#B91C1C"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content View Area -->
            <ContentControl Grid.Row="1"
                           Content="{Binding CurrentView}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>
            
            <!-- Company Footer Section -->
            <Border Grid.Row="2"
                   Padding="20,15"
                   BorderBrush="#E5E7EB"
                   BorderThickness="0,1,0,0">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="1"
                            Text="{Binding CompanyInfo, Mode=TwoWay}"
                            FontSize="12"
                            Foreground="#1F2937"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            HorizontalAlignment="Stretch"
                            Padding="8,4"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            TextAlignment="Center"
                            Watermark="Informations de l'entreprise">
                        <TextBox.Styles>
                            <Style Selector="TextBox">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style Selector="TextBox:focus">
                                <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </TextBox.Styles>
                    </TextBox>
                </Grid>
            </Border>
          
        </Grid>
        </ScrollViewer>
    </Grid>
</Window>
