<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AroniumFactures.ViewModels"
        xmlns:local="clr-namespace:AroniumFactures"
        xmlns:views="clr-namespace:AroniumFactures.UserControls"
        xmlns:helpers="clr-namespace:AroniumFactures.Helpers"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
        x:Class="AroniumFactures.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{x:Static local:Strings.AppTitle}"
        Width="1000" Height="800"
        Background="#F0F2F5">
    <Window.Resources>
        <helpers:SidebarPageToBoolConverter x:Key="SidebarPageToBoolConverter"/>
    </Window.Resources>
    <Grid PointerPressed="MainGrid_PointerPressed" RowDefinitions="Auto,Auto,*">
        <!-- Update Banner -->
        <Border Grid.Row="0"
                Background="#10B981"
                Padding="15,12"
                IsVisible="{Binding IsUpdateAvailable}"
                Cursor="Hand">
            <Border.Styles>
                <Style Selector="Border:pointerover">
                    <Setter Property="Background" Value="#059669"/>
                </Style>
            </Border.Styles>
            <Button Command="{Binding DownloadUpdateCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="🔄 Une nouvelle mise à jour est disponible. Cliquez pour télécharger et installer."
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="⬇️"
                               Foreground="White"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </Grid>
            </Button>
        </Border>
        
        <!-- Top Bar with Settings Button (Always Enabled) -->
        <Border Grid.Row="1"
                Background="White"
                Padding="15,10"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                BoxShadow="0 1 3 0 #10000000">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{x:Static local:Strings.AppTitle}"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="⚙️ Paramètres"
                        Command="{Binding OpenSettingsCommand}"
                        Background="#6B7280"
                        Foreground="White"
                        Padding="15,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        CornerRadius="6"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#4B5563"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>
        </Border>
        
        <!-- Sidebar + Content area -->
        <Grid Grid.Row="2" ColumnDefinitions="220,*">
            <!-- Sidebar -->
            <Border Grid.Column="0" 
                    Background="White" 
                    BorderBrush="#E5E7EB" 
                    BorderThickness="0,0,1,0"
                    BoxShadow="0 1 3 0 #10000000">
                <StackPanel Margin="12,20" Spacing="4">
                    <Button Content="📄 Facture"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="{x:Static vm:SidebarPage.Facture}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="16,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="#10B981"
                            Foreground="White"
                            CornerRadius="8"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#059669"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Border>
            <!-- Content area: switch between UserControls by visibility -->
            <Grid Grid.Column="1" IsEnabled="{Binding IsInteractive}">
                <views:FactureView IsVisible="{Binding CurrentPage, Converter={StaticResource SidebarPageToBoolConverter}, ConverterParameter={x:Static vm:SidebarPage.Facture}}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
