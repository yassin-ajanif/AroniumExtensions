<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AroniumFactures.ViewModels"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="1200"
        x:Class="AroniumFactures.UserControls.FactureUserControl"
        x:DataType="vm:FactureViewModel"
        Background="White">
    
    <ScrollViewer>
        <Grid Margin="40" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
            
            <!-- Header Title -->
            <TextBlock Grid.Row="0"
                      Text="FACTURE"
                      FontSize="24"
                      FontWeight="Bold"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,30"
                      Foreground="#1F2937"/>
            
            <!-- Document Search Section -->
            <Border Grid.Row="1"
                   Background="White"
                   Padding="15"
                   CornerRadius="8"
                   BorderBrush="#E5E7EB"
                   BorderThickness="1"
                   Margin="0,0,0,20">
                <Grid ColumnDefinitions="Auto,250,Auto,Auto,*">
                    <TextBlock Text="N° Document:" 
                              VerticalAlignment="Center"
                              FontWeight="SemiBold"
                              Margin="0,0,15,0"/>
                    
                    <TextBox Grid.Column="1"
                            Text="{Binding SearchDocumentNumber, Mode=TwoWay}"
                            Watermark="25-200-000002"
                            VerticalContentAlignment="Center"
                            Padding="10,8"/>
                    
                    <Button Grid.Column="2"
                           Content="📄 Charger"
                           Command="{Binding LoadDocumentCommand}"
                           IsEnabled="{Binding !IsLoadingDocument}"
                           Margin="10,0,0,0"
                           Background="#10B981"
                           Foreground="White"
                           Padding="20,8"
                           FontWeight="SemiBold"
                           CornerRadius="6"
                           BorderThickness="0"
                           Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#059669"/>
                            </Style>
                            <Style Selector="Button:disabled">
                                <Setter Property="Background" Value="#D1D5DB"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                    <Button Grid.Column="3"
                           Content="🖨️ Imprimer"
                           Command="{Binding PrintFactureCommand}"
                           IsEnabled="{Binding !IsPrinting}"
                           Margin="10,0,0,0"
                           Background="#2563EB"
                           Foreground="White"
                           Padding="20,8"
                           FontWeight="SemiBold"
                           CornerRadius="6"
                           BorderThickness="0"
                           Cursor="Hand">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Style>
                            <Style Selector="Button:disabled">
                                <Setter Property="Background" Value="#D1D5DB"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                    <TextBlock Grid.Column="4"
                              Text="{Binding LoadDocumentStatus}"
                              VerticalAlignment="Center"
                              Margin="15,0,0,0"
                              FontSize="13"/>
                </Grid>
            </Border>
            
            <!-- Invoice Information Section -->
            <Border Grid.Row="2"
                   Background="#F9FAFB"
                   Padding="20"
                   CornerRadius="8"
                   BorderBrush="#E5E7EB"
                   BorderThickness="1"
                   Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="INFORMATIONS FACTURE"
                              FontSize="14"
                              FontWeight="Bold"
                              Margin="0,0,0,15"
                              Foreground="#374151"/>
                    <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="15">
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                  Text="Numéro:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                Text="{Binding InvoiceNumber, Mode=TwoWay}"
                                Foreground="#1F2937"
                                Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                Padding="8,6"/>
                        
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                  Text="Date:"
                                  FontWeight="SemiBold"
                                  Margin="15,0,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"/>
                        <DatePicker Grid.Row="0" Grid.Column="3"
                                   SelectedDate="{Binding InvoiceDate, Mode=TwoWay}"
                                   Background="White"
                                   BorderBrush="#D1D5DB"
                                   BorderThickness="1"
                                   Padding="8,6"
                                   FontSize="13"
                                   Foreground="#1F2937"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                  Text="Bon de Livraison N°:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                Text="{Binding DeliveryNoteNumber, Mode=TwoWay}"
                                Foreground="#1F2937"
                                Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                Padding="8,6"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="2"
                                  Text="N° de Bon de commande:"
                                  FontWeight="SemiBold"
                                  Margin="15,0,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="3"
                                Text="{Binding OrderNumber, Mode=TwoWay}"
                                Foreground="#1F2937"
                                Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                Padding="8,6"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                  Text="N° de Devis:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                Text="{Binding QuotationNumber, Mode=TwoWay}"
                                Foreground="#1F2937"
                                Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                Padding="8,6"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Client Information Section -->
            <Border Grid.Row="3"
                   Background="#F9FAFB"
                   Padding="20"
                   CornerRadius="8"
                   BorderBrush="#E5E7EB"
                   BorderThickness="1"
                   Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="CLIENT INFORMATION"
                              FontSize="14"
                              FontWeight="Bold"
                              Margin="0,0,0,15"
                              Foreground="#374151"/>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                  Text="Client:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                Text="{Binding ClientName, Mode=TwoWay}"
                                Foreground="#1F2937"
                                Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                Padding="8,6"/>
                        
                        <!-- Temporarily hidden - Address field
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                  Text="Address:"
                                  FontWeight="SemiBold"
                                  Margin="0,8,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Top"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                Text="{Binding ClientAddress, Mode=TwoWay}"
                                Foreground="#1F2937"
                                Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                Padding="8,6"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MinHeight="60"/>
                        -->
                        
                        <!-- Temporarily hidden - Site field
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                  Text="Site:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                Text="{Binding ClientSite, Mode=TwoWay}"
                                Foreground="#1F2937"
                                Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                Padding="8,6"/>
                        -->
                        
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                  Text="ICE:"
                                  FontWeight="SemiBold"
                                  Margin="0,0,15,0"
                                  Foreground="#4B5563"
                                  VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                Text="{Binding ClientIce, Mode=TwoWay}"
                                Foreground="#1F2937"
                                Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                Padding="8,6"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Items Table Section -->
            <Border Grid.Row="4"
                   BorderBrush="#E5E7EB"
                   BorderThickness="1"
                   Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Table Header -->
                    <Border Grid.Row="0"
                           Background="#374151"
                           Padding="12,10">
                        <Grid ColumnDefinitions="40,*,100,80,100,120">
                            <TextBlock Grid.Column="0" Text="N°" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="DESIGNATION" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="10,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="UNITE" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="QTE" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="PU HT" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="5" Text="PT HT" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" Margin="10,0,0,0"/>
                        </Grid>
                    </Border>
                    
                    <!-- Table Items -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="White" Padding="12,10">
                                    <Border.Styles>
                                        <Style Selector="Border:nth-child(even)">
                                            <Setter Property="Background" Value="#F9FAFB"/>
                                        </Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="40,*,100,80,100,120">
                                        <TextBlock Grid.Column="0" Text="{Binding Reference}" Foreground="#1F2937" FontSize="13"/>
                                        <TextBox Grid.Column="1" 
                                                Text="{Binding Designation, Mode=TwoWay}" 
                                                Foreground="#1F2937" 
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                FontSize="13"
                                                TextWrapping="Wrap"
                                                Margin="10,0,0,0"
                                                Padding="4,2">
                                            <TextBox.Styles>
                                                <Style Selector="TextBox:focus">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Style>
                                            </TextBox.Styles>
                                        </TextBox>
                                        <TextBox Grid.Column="2" 
                                                Text="{Binding Unit, Mode=TwoWay}" 
                                                Foreground="#1F2937" 
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                FontSize="13"
                                                HorizontalAlignment="Center"
                                                HorizontalContentAlignment="Center"
                                                Padding="4,2">
                                            <TextBox.Styles>
                                                <Style Selector="TextBox:focus">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Style>
                                            </TextBox.Styles>
                                        </TextBox>
                                        <NumericUpDown Grid.Column="3" 
                                                      Value="{Binding Quantity, Mode=TwoWay}" 
                                                      Foreground="#1F2937" 
                                                      Background="Transparent"
                                                      BorderBrush="Transparent"
                                                      BorderThickness="0"
                                                      FontSize="13"
                                                      HorizontalAlignment="Center"
                                                      HorizontalContentAlignment="Center"
                                                      Minimum="0"
                                                      Increment="0.01"
                                                      FormatString="F2"
                                                      ShowButtonSpinner="False"
                                                      Padding="4,2">
                                            <NumericUpDown.Styles>
                                                <Style Selector="NumericUpDown:focus">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Style>
                                            </NumericUpDown.Styles>
                                        </NumericUpDown>
                                        <TextBlock Grid.Column="4" 
                                                  Text="{Binding UnitPrice, StringFormat={}{0:N2}}" 
                                                  Foreground="#1F2937" 
                                                  FontSize="13"
                                                  HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="5" 
                                                  Text="{Binding TotalHT, StringFormat={}{0:N2}}" 
                                                  Foreground="#1F2937" 
                                                  FontSize="13"
                                                  FontWeight="SemiBold"
                                                  HorizontalAlignment="Right"
                                                  Margin="10,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
            
            <!-- Totals Section -->
            <Border Grid.Row="5"
                   Background="#F9FAFB"
                   Padding="20"
                   CornerRadius="8"
                   BorderBrush="#E5E7EB"
                   BorderThickness="1"
                   Margin="0,0,0,20">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="TOTAL GENERAL H.T ="
                                  FontSize="15"
                                  FontWeight="Bold"
                                  Foreground="#1F2937"/>
                        <TextBlock Grid.Column="1"
                                  Text="{Binding TotalHTDisplay}"
                                  FontSize="15"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Right"
                                  Foreground="#1F2937"/>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding VatRate, StringFormat='T.V.A {0}% ='}"
                                  FontSize="15"
                                  FontWeight="Bold"
                                  Foreground="#1F2937"/>
                        <TextBlock Grid.Column="1"
                                  Text="{Binding VatAmountDisplay}"
                                  FontSize="15"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Right"
                                  Foreground="#1F2937"/>
                    </Grid>
                    
                    <Rectangle Height="2" Fill="#D1D5DB" Margin="0,5"/>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="TOTAL LOT GENERAL TTC ="
                                  FontSize="17"
                                  FontWeight="Bold"
                                  Foreground="#1F2937"/>
                        <TextBlock Grid.Column="1"
                                  Text="{Binding TotalTTCDisplay}"
                                  FontSize="17"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Right"
                                  Foreground="#2563EB"/>
                    </Grid>
                </StackPanel>
            </Border>
            
        </Grid>
    </ScrollViewer>
</UserControl>

